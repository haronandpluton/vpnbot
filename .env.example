# Telegram bot token from BotFather
BOT_TOKEN=your_bot_token_here

# Telegram admin IDs separated by comma
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=123456789

# PostgreSQL async connection URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vpn_bot

# Logging level
LOG_LEVEL=INFO

# Development mode
# true  — dev/test commands and routers are available for admins
# false — dev/test routers are not loaded, dev commands are blocked
DEV_MODE=false


ORDER_EXPIRATION_SCHEDULER_ENABLED=true
ORDER_EXPIRATION_INTERVAL_SECONDS=600
ORDER_EXPIRATION_INITIAL_DELAY_SECONDS=45
# CryptoBot / Crypto Pay
CRYPTOBOT_ENABLED=false
CRYPTOBOT_API_URL=https://pay.crypt.bot/api
CRYPTOBOT_API_TOKEN=
# Legacy default only; new invoices use the currency selected per order.
CRYPTOBOT_ASSET=USDT
CRYPTOBOT_ASSET=USDT
CRYPTOBOT_EXPIRES_IN=900

# Telegram Stars payments
TELEGRAM_STARS_ENABLED=false
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_STARS_INVOICE_SECRET=
# Public ZA gateway used in links sent by the bot
VPN_SUBSCRIPTION_PUBLIC_BASE_URL=https://connect.presentvpn.click

# Export active/expired/disabled subscription metadata to the ZA gateway
SUBSCRIPTION_META_OUTPUT_PATH=deploy/vpn-subscription/subscriptions_meta.generated.json
# Example: vpnadmin@139.84.251.197:/opt/vpn-subscription/subscriptions_meta.json
SUBSCRIPTION_META_REMOTE_TARGET=
# Optional path to a dedicated SSH private key used by scp
SUBSCRIPTION_META_SSH_KEY=
SUBSCRIPTION_META_SYNC_TIMEOUT_SECONDS=60
SUBSCRIPTION_META_RETRY_SCHEDULER_ENABLED=true
SUBSCRIPTION_META_RETRY_INTERVAL_SECONDS=120
SUBSCRIPTION_META_RETRY_INITIAL_DELAY_SECONDS=60
